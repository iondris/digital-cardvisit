RewriteEngine On

# If you will upload this project under: https://yourdomain.com/kartvizit/
# Keep this line:
RewriteBase /kartvizit/

# Don't rewrite real files/folders (assets, data, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Pretty URL:
# /kartvizit/yunus  -> /kartvizit/index.html?id=yunus
RewriteRule ^([A-Za-z0-9_-]+)/?$ index.html?id=$1 [L,QSA]

